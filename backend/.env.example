# ── WhatsApp Cloud API (Meta) ──────────────────────────────────────────
# App Secret: Meta Developer Console → Your App → App Settings → Basic
META_APP_SECRET=your_app_secret_here
# Verify Token: any random string you choose, paste same in Meta webhook config
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here
# From Meta Developer Console → WhatsApp → API Setup
META_PHONE_NUMBER_ID=your_phone_number_id
META_WABA_ID=your_waba_id
# System User Token (permanent): Meta Business Suite → System Users
META_SYSTEM_USER_TOKEN=your_permanent_system_user_token_here

# ── Voice Transcription (Groq Whisper - FREE) ─────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# ── Voice Reply (OpenAI TTS) & Image Vision ───────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
